# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Node Environment
NODE_ENV=development

# Database Configuration
MYSQL_URL=mysql://username:password@localhost:3306/autoimage

# Stripe Configuration - Development
STRIPE_SECRET_TEST_KEY=sk_test_your_test_secret_key_here
STRIPE_PUBLISHABLE_TEST_KEY=pk_test_your_test_publishable_key_here
STRIPE_WEBHOOK_SECRET_TEST=whsec_your_test_webhook_secret_here

# Stripe Configuration - Production (only set these in production)
# STRIPE_SECRET_KEY=sk_live_your_live_secret_key_here
# STRIPE_PUBLISHABLE_KEY=pk_live_your_live_publishable_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_live_webhook_secret_here

# Email Configuration
RESEND_API_KEY=re_your_resend_api_key_here

# Server Configuration
PORT=3200

# AI/OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Session Configuration (optional)
SESSION_SECRET=your_random_session_secret_here

# Security Configuration (optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging Configuration (optional)
LOG_LEVEL=info
LOG_FILE=logs/app.log
