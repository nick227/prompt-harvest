{
    "name": "power-prompt",
    "version": "1.0.0",
    "description": "",
    "main": "server.js",
    "type": "module",
    "scripts": {
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "fix:optional-chaining": "node scripts/fix-optional-chaining.js",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:debug": "playwright test --config=tests/e2e/e2e.config.js --debug",
        "test:e2e:errors": "playwright test tests/e2e/javascript-errors.spec.js",
        "test:e2e:enhanced-auth": "playwright test tests/e2e/enhanced-auth-flow.spec.js",
        "test:error-detection": "node scripts/test-error-detection.js",
        "lint:critical": "node scripts/strict-lint-check.js",
        "pre-commit": "npm run lint:fix && npm run test",
        "test:e2e:terms": "playwright test tests/e2e/terms.spec.js",
        "test:e2e:terms-ai": "playwright test tests/e2e/terms-ai.spec.js",
        "test:e2e:terms-all": "playwright test tests/e2e/terms*.spec.js",
        "test:e2e:setup": "node tests/e2e/setup/global-setup.js",
        "test:e2e:billing": "playwright test tests/e2e/billing-flows.spec.js --config=tests/e2e/billing.config.js",
        "test:e2e:billing:ui": "playwright test tests/e2e/billing-flows.spec.js --config=tests/e2e/billing.config.js --ui",
        "test:e2e:billing:headed": "playwright test tests/e2e/billing-flows.spec.js --config=tests/e2e/billing.config.js --headed",
        "test:e2e:billing:debug": "playwright test tests/e2e/billing-flows.spec.js --config=tests/e2e/billing.config.js --debug",
        "test:all": "npm run test:coverage && npm run test:e2e",
        "lint": "eslint public/js/**/*.js",
        "lint:fix": "eslint public/js/**/*.js --fix",
        "lint:strict": "eslint public/js/**/*.js --max-warnings=0",
        "lint:format": "prettier --write public/js/**/*.js",
        "lint:check": "prettier --check public/js/**/*.js",
        "quality": "npm run lint:strict && npm run test:coverage",
        "start": "node server.js",
        "dev": "nodemon server.js",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:deploy": "prisma migrate deploy",
        "db:studio": "prisma studio",
        "db:seed": "node scripts/seed-database.js",
        "db:migrate-data": "node scripts/migrate-to-mysql.js",
        "db:migrate-images": "node scripts/migrate-images-properly.js",
        "db:setup": "node scripts/setup-database.js",
        "db:reset": "prisma migrate reset",
        "db:status": "prisma migrate status",
        "test:smart": "node tests/smart-image-generation-simple.js",
        "test:smart:verbose": "node tests/smart-image-generation-simple.js --verbose",
        "test:frontend-api": "node scripts/test-frontend-api.js",
        "test:transactions": "node scripts/test-transaction-api.js",
        "test:transactions:improvements": "node scripts/test-transaction-improvements.js",
        "test:widget": "node scripts/test-widget.js",
        "test:button": "node scripts/test-button-fix.js",
        "test:simplified": "node scripts/test-simplified-system.js",
        "test:cleaned": "node scripts/test-cleaned-system.js",
        "test:app": "node scripts/test-app-initialization.js",
        "test:unit": "jest tests/unit",
        "test:integration": "jest tests/integration",
        "stripe:listen": "stripe listen --forward-to localhost:3200/webhook",
        "stripe:check": "node scripts/check-stripe-cli.js",
        "dev:with-stripe": "npm run stripe:check && npm run dev",
        "start:with-stripe": "npm run stripe:check && npm run start"
    },
    "dependencies": {
        "@langchain/community": "^0.0.32",
        "@langchain/openai": "^0.0.11",
        "@prisma/client": "^6.15.0",
        "async": "^3.2.5",
        "axios": "^1.6.8",
        "bcryptjs": "^2.4.3",
        "body-parser": "^1.20.2",
        "cheerio": "^1.0.0-rc.12",
        "completions": "^2.9.0",
        "compression": "^1.7.4",
        "compromise": "^14.12.0",
        "cors": "^2.8.5",
        "datamuse": "^1.0.5",
        "dotenv": "^16.4.5",
        "elevenlabs-node": "^2.0.3",
        "express": "^4.18.2",
        "express-session": "^1.18.0",
        "fs": "^0.0.1-security",
        "i": "^0.3.7",
        "jsonwebtoken": "^9.0.2",
        "langchain": "^0.0.165",
        "llamaindex": "^0.0.46",
        "module-alias": "^2.2.3",
        "mongoose": "^7.6.1",
        "multer": "^1.4.5-lts.1",
        "nedb": "^1.8.0",
        "nlp": "^0.0.0",
        "npm": "^10.4.0",
        "openai": "^4.11.1",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "passport-local": "^1.0.0",
        "pdfreader": "^3.0.2",
        "prisma": "^6.15.0",
        "readline": "^1.3.0",
        "resend": "^6.0.2",
        "sharp": "^0.33.4",
        "stripe": "^14.21.0",
        "supabase": "^1.145.4",
        "util": "^0.12.5",
        "ws": "^8.14.2"
    },
    "devDependencies": {
        "@babel/core": "^7.24.0",
        "@babel/preset-env": "^7.24.0",
        "@playwright/test": "^1.55.0",
        "babel-jest": "^29.7.0",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-jest": "^28.6.0",
        "eslint-plugin-node": "^11.1.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "jsdom": "^26.1.0",
        "nodemon": "^3.1.0",
        "prettier": "^3.2.5",
        "supertest": "^7.1.4"
    },
    "author": "nrios",
    "license": "ISC"
}
